---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  schema?: object[];
  ogImage?: string;
  ogType?: string;
  robots?: string;
  noIndex?: boolean;
}

const {
  title,
  description = "Professional corporate services and legal support for businesses in Switzerland.",
  schema = [],
  ogImage = "https://lawsupport.ch/images/lawsupport.webp",
  ogType = "website",
  robots,
  noIndex = false,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, "https://lawsupport.ch");

const organizationSchema = {
  "@type": ["LegalService", "LocalBusiness"],
  "@id": "https://lawsupport.ch/#organization",
  "name": "Morgan Hartley Consulting",
  "url": "https://lawsupport.ch",
  "logo": {
    "@type": "ImageObject",
    "@id": "https://lawsupport.ch/#logo",
    "url": "https://lawsupport.ch/images/logo.png"
  },
  "image": {"@id": "https://lawsupport.ch/#logo"},
  "description": "Professional corporate services and legal support for businesses in Switzerland.",
  "telephone": "+41445152592",
  "email": "info@lawsupport.ch",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Baarerstrasse 135",
    "addressLocality": "Zug",
    "postalCode": "6300",
    "addressCountry": "CH"
  },
  "knowsAbout": ["Swiss corporate law", "company formation", "shelf companies", "financial services licensing", "SECO permits", "residence permits", "Swiss bank accounts", "accounting"],
  "sameAs": ["https://x.com/Law_Switzerland", "https://www.instagram.com/law_support.switzerland"],
  "foundingDate": "2003",
  "numberOfEmployees": {"@type": "QuantitativeValue", "value": 12},
  "priceRange": "$$$",
  "openingHoursSpecification": {
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
    "opens": "09:00",
    "closes": "18:00"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+41445152592",
    "contactType": "Customer Service",
    "areaServed": "CH",
    "availableLanguage": ["English", "German"]
  }
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": "https://lawsupport.ch/#website",
  "name": "Morgan Hartley Consulting",
  "url": "https://lawsupport.ch",
  "publisher": {"@id": "https://lawsupport.ch/#organization"}
};

const personSchema = {
  "@type": "Person",
  "@id": "https://lawsupport.ch/#morgan-hartley",
  "name": "Morgan Hartley",
  "jobTitle": "Lawyer",
  "affiliation": {"@id": "https://lawsupport.ch/#organization"},
  "hasCredential": [
    {"@type": "EducationalOccupationalCredential", "name": "Swiss Bar Admission, Canton of Zurich"},
    {"@type": "EducationalOccupationalCredential", "name": "LLM, University of Zurich"},
    {"@type": "EducationalOccupationalCredential", "name": "lic. iur., University of Bern"}
  ],
  "memberOf": [
    {"@type": "Organization", "name": "Swiss Bar Association"},
    {"@type": "Organization", "name": "Zurich Bar Association"}
  ],
  "email": "m.hartley@lawsupport.ch",
  "areaServed": [
    { "@type": "AdministrativeArea", "name": "Zurich" },
    { "@type": "AdministrativeArea", "name": "Zug" }
  ],
  "availableLanguage": ["English", "German", "French", "Russian"]
};

const graphSchema = {
  "@context": "https://schema.org",
  "@graph": [organizationSchema, websiteSchema, personSchema, ...schema]
};
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="generator" content={Astro.generator} />
  <title>{title}</title>
  <meta name="description" content={description} />
  {robots && <meta name="robots" content={robots} />}
  {!noIndex && <link rel="canonical" href={canonicalURL} />}
  <link rel="icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <!-- Open Graph -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:type" content={ogType} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:site_name" content="Morgan Hartley Consulting" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preload" href="/fonts/guton-regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/guton-medium.woff2" as="font" type="font/woff2" crossorigin />
  {!noIndex && <script type="application/ld+json" set:html={JSON.stringify(graphSchema)} />}
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
  <script src="/js/form-handler.js?v=2" defer></script>
</body>
</html>
