---
import Base from './Base.astro';

interface Props {
  title: string;
  description?: string;
  category?: string;
  categoryHref?: string;
  date?: string;
  readTime?: string;
  tocItems?: { id: string; title: string }[];
  faqItems?: { question: string; answer: string }[];
  heroImage?: string;
  relatedArticles?: { title: string; href: string; image?: string }[];
}

const {
  title,
  description = '',
  category = 'Swiss Company Formation',
  categoryHref = '/swiss-company-formation/',
  date = '06.03.2026',
  readTime = '4 min read',
  heroImage = '',
  tocItems = [],
  faqItems = [],
  relatedArticles = [],
} = Astro.props;

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "datePublished": date.split(".").reverse().join("-"),
    "dateModified": date.split(".").reverse().join("-"),
    "author": { "@type": "Person", "@id": "https://lawsupport.ch/#morgan-hartley", "name": "Morgan Hartley", "jobTitle": "Senior Corporate Lawyer & Partner" },
    "publisher": { "@type": "Organization", "name": "Lawsupport.ch" }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": title,
    "url": `https://lawsupport.ch${Astro.url.pathname}`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" },
      { "@type": "ListItem", "position": 2, "name": category, "item": `https://lawsupport.ch${categoryHref}` },
      { "@type": "ListItem", "position": 3, "name": title, "item": `https://lawsupport.ch${Astro.url.pathname}` }
    ]
  },
  ...(faqItems.length > 0 ? [{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqItems.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": { "@type": "Answer", "text": f.answer }
    }))
  }] : [])
];
---

<Base title={`${title} — Lawsupport.ch`} description={description} schema={schema}>

  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span>
      <a href={categoryHref}>{category}</a> <span>/</span>
      <span>{title}</span>
    </nav>
  </div>

  <!-- Article Hero -->
  <section class="article-hero">
    <div class="container">
      <div class="article-hero-grid">
        <div class="article-hero-content">
          <div class="article-meta">
            <span class="article-date">{date} &bull; {readTime}</span>
            <a href={categoryHref} class="article-category">{category}</a>
          </div>
          <h1>{title}</h1>
          {description && <p class="article-desc">{description}</p>}
        </div>
        <div class="article-hero-image">
          {heroImage ? <img src={heroImage.replace(".png",".webp")} srcset={heroImage.replace(".png","-375.webp") + " 375w, " + heroImage.replace(".png",".webp") + " 750w"} sizes="(max-width: 640px) 375px, 640px" alt={title} class="article-hero-img" width="750" height="419" fetchpriority="high" /> : <div class="article-hero-placeholder"></div>}
        </div>
      </div>
    </div>
  </section>

  <!-- Two-column: content + sidebar -->
  <section class="article-section">
    <div class="container">
      <div class="article-layout">
        <div class="article-content">
          <slot />
        </div>
        <aside class="article-sidebar">
          {tocItems.length > 0 && (
            <div class="toc">
              <p class="sidebar-heading">Table of Contents</p>
              <ul>
                {tocItems.map(item => (
                  <li><a href={`#${item.id}`}>{item.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          <div class="sidebar-contact">
            <p class="sidebar-heading">Contact Us</p>
            <div class="sidebar-author">
              <img src="/images/morgan-hartley-56.webp" alt="Morgan Hartley" width="56" height="56" loading="lazy" class="sidebar-avatar" />
              <div class="sidebar-author-info">
                <p>Morgan Hartley</p>
                <span>Senior Corporate Lawyer &amp; Partner</span>
              </div>
            </div>
            <div class="sidebar-contact-links">
              <a href="tel:+41445152590" aria-label="Phone">
                <img src="/icons/tel.svg" alt="Phone" width="18" height="18" style="width:18px;height:18px;display:inline-block" />
              </a>
              <a href="mailto:info@lawsupport.ch" aria-label="Email">
                <img src="/icons/massage.svg" alt="Email" width="18" height="18" style="width:18px;height:18px;display:inline-block" />
              </a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {faqItems.length > 0 && (
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title">FAQ</h2>
        <div class="faq-list">
          {faqItems.map(item => (
            <div class="faq-item">
              <button class="faq-question">{item.question}</button>
              <div class="faq-answer">
                <div class="faq-answer-inner">{item.answer}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Articles -->
  {relatedArticles.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Related Articles</h2>
        <div class="grid-3 related-grid">
          {relatedArticles.map(article => (
            <a href={article.href} class="card">
              <div class="card-img" style={article.image ? `background-image:url(${article.image});background-size:cover;background-position:center` : 'background:#ddd'}></div>
              <div class="card-body">
                <h3>{article.title}</h3>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
  .article-hero {
    padding: 24px 0 48px;
    border-bottom: 4px solid var(--red);
  }
  .article-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: center;
  }
  .article-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .article-date { font-size: 0.85rem; color: var(--gray-text); }
  .article-category {
    display: inline-block;
    padding: 4px 12px;
    background: var(--black);
    color: var(--white);
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 500;
  }
  .article-desc {
    color: var(--gray-text);
    margin-top: 16px;
    max-width: 600px;
  }
  .article-hero-placeholder {
    width: 100%;
    height: 280px;
    background: #ddd;
    border-radius: 12px;
  }
  .article-hero-img {
    width: 100%;
    height: auto;
    max-height: 350px;
    object-fit: cover;
    border-radius: 12px;
    aspect-ratio: 750/419;
  }

  /* layout styles moved to global.css */

  .sidebar-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .faq-list { max-width: 800px; margin: 0 auto; }

  @media (min-width: 768px) {
    .article-hero-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    /* desktop layout in global.css */
  }
</style>

<script>
  document.querySelectorAll('.faq-question').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      item?.classList.toggle('active');
    });
  });

  // TOC active state on scroll
  const tocLinks = document.querySelectorAll('.toc a');
  if (tocLinks.length > 0) {
    const headings = Array.from(tocLinks).map(link => {
      const id = link.getAttribute('href')?.slice(1);
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.toc a[href="#${entry.target.id}"]`);
          active?.classList.add('active');
        }
      });
    }, { rootMargin: '-80px 0px -60% 0px' });

    headings.forEach(h => observer.observe(h));
  }
</script>
