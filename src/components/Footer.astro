---
const services = [
  { title: "Swiss Company Formation", href: "/services/company-formation/" },
  { title: "Shelf Companies", href: "/services/shelf-companies/" },
  { title: "Financial Licensing", href: "/services/financial-licensing/" },
  { title: "SECO Work Permits", href: "/services/seco-permits/" },
  { title: "Corporate Bank Account", href: "/banking/corporate-bank-account-switzerland/" },
  { title: "Accounting In Switzerland", href: "/tax-accounting/accounting-switzerland/" },
  { title: "Resident Card In Switzerland", href: "/immigration/b-permit-switzerland/" },
  { title: "Company Liquidation In Switzerland", href: "/company-formation/company-liquidation-switzerland/" },
];
---

<footer class="footer">
  <div class="footer-top container">
    <div class="footer-col">
      <a href="/" class="footer-logo">
        <img src="/images/logo.png" srcset="/images/logo.png 1x, /images/logo@2x.png 2x, /images/logo@3x.png 3x" alt="Lawsupport" width="40" height="28" />
        <div class="footer-logo-text">
          <strong>LAW SUPPORT</strong>
          <span>Corporate Services in Switzerland</span>
        </div>
      </a>
      <p class="footer-desc">Professional corporate services and legal support for businesses in Switzerland.</p>
      <div class="footer-socials">
        <a href="https://x.com/Law_Switzerland" target="_blank" rel="nofollow noopener" aria-label="X (Twitter)"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg></a>
        <a href="https://www.facebook.com/goldblum.and.partners" target="_blank" rel="nofollow noopener" aria-label="Facebook"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg></a>
        <a href="https://www.instagram.com/law_support.switzerland" target="_blank" rel="nofollow noopener" aria-label="Instagram"><svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg></a>
      </div>
    </div>
    <div class="footer-col">
      <h4>Services</h4>
      <ul>
        {services.map(s => <li><a href={s.href}>{s.title}</a></li>)}
      </ul>
    </div>
    <div class="footer-col">
      <h4>Company</h4>
      <ul>
        <li><a href="/about/">About Us</a></li>
        <li><a href="/blog/">Blog</a></li>
        <li><a href="/contacts/">Contacts</a></li>
        <li><a href="/privacy-policy/">Privacy Policy</a></li>
        <li><a href="/privacy-policy/">Cookies Policy</a></li>
        <li><a href="/terms/">Terms of Service</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h4>Contact</h4>
      <p class="footer-contact-name"><strong>Morgan Hartley Consulting</strong></p>
      <p class="footer-contact-line">Baarerstrasse 135, 6300 Zug, Switzerland</p>
      <p class="footer-contact-line"><a href="tel:+41445152592">+41 44 51 52 592</a></p>
      <a href="/contacts/" class="btn btn-red" style="margin-top:16px;display:inline-block;padding:10px 24px;font-size:0.85rem">Contact Us</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>&copy; 2007 &ndash; 2026 Morgan Hartley Consulting. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--black); color: var(--white); padding-top: 64px; }
  .footer-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-bottom: 48px;
  }
  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .footer-logo-text { display: flex; flex-direction: column; line-height: 1.2; }
  .footer-logo-text strong { font-size: 1rem; letter-spacing: 0.5px; }
  .footer-logo-text span { font-size: 0.65rem; color: var(--gray-text); }
  .footer-desc { color: #999; font-size: 0.9rem; margin-bottom: 20px; }
  .footer-socials { display: flex; gap: 12px; }
  .footer-socials a {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid #333; color: #999; transition: border-color 0.2s, color 0.2s;
  }
  .footer-socials a:hover { border-color: var(--red); color: var(--white); }

  .footer-col h4 { font-size: 1rem; margin-bottom: 16px; }
  .footer-col ul li { margin-bottom: 10px; }
  .footer-col ul a { color: #999; font-size: 0.9rem; transition: color 0.2s; }
  .footer-col ul a:hover { color: var(--white); }
  .footer-col ul li:not(:has(a)) { color: #999; font-size: 0.9rem; }

  .footer-contact-name { font-size: 0.9rem; margin-bottom: 4px; }
  .footer-contact-line { color: #999; font-size: 0.9rem; margin-bottom: 2px; }
  .footer-contact-line a { color: #999; transition: color 0.2s; }
  .footer-contact-line a:hover { color: var(--white); }

  .footer-phone a {
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--white) !important;
  }

  .footer-bottom {
    border-top: 1px solid #222;
    padding: 24px 0;
  }
  .footer-bottom p { color: #666; font-size: 0.85rem; text-align: center; }

  @media (min-width: 768px) {
    .footer-top { grid-template-columns: 2fr 1fr 1fr 1fr; }
  }
</style>
