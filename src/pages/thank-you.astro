---
import Base from '../layouts/Base.astro';
---
<Base title="Thank You — Lawsupport.ch" description="Your message has been sent successfully.">
  <section class="section">
    <div class="container" style="text-align:center;min-height:40vh;display:flex;flex-direction:column;align-items:center;justify-content:center">
      <h1 style="color:#E31E24">Thank You</h1>
      <p style="color:#555;margin:16px 0 32px;max-width:480px">Your message has been sent. We will get back to you within 24 hours.</p>
      <a href="/" class="btn btn-red">Back to Homepage</a>
    </div>
  </section>
</Base>
