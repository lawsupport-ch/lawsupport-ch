---
import Base from '../layouts/Base.astro';

const schema = [
  {
    "@type": "WebPage",
    "name": "Contact Swiss Corporate Lawyers — Zug | Morgan Hartley",
    "description": "Contact our Swiss corporate law team in Zug. Free initial consultation for company formation, licensing, and legal support.",
    "url": "https://lawsupport.ch/contacts/"
  },
  {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" },
      { "@type": "ListItem", "position": 2, "name": "Contacts", "item": "https://lawsupport.ch/contacts/" }
    ]
  },

  {
    "@type": "LocalBusiness",
    "@id": "https://lawsupport.ch/#office",
    "name": "Morgan Hartley Consulting",
    "description": "Swiss corporate law firm offering company formation, legal support, and business consulting.",
    "url": "https://lawsupport.ch/contacts/",
    "telephone": "+41 44 51 52 592",
    "email": "info@lawsupport.ch",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Baarerstrasse 135",
      "addressLocality": "Zug",
      "postalCode": "6300",
      "addressCountry": "CH"
    },
    "openingHours": "Mo-Fr 09:00-18:00",
    "image": "https://lawsupport.ch/images/lawsupport.webp"
  }
];
---

<Base title="Contact Swiss Corporate Lawyers — Zug | Morgan Hartley" description="Contact our Swiss corporate law team in Zug. Free initial consultation for company formation, licensing, and legal support." schema={schema}>

  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>Contacts</span>
    </nav>
  </div>

  <section class="section">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="contacts-lead">We are happy to help you with any questions regarding corporate services and legal support in Switzerland.</p>

      <div class="contacts-grid">
        <!-- Form -->
        <div class="contacts-form-wrap">
          <form class="contact-form" id="contact-form">
            <div class="form-group">
              <label for="c-name">Name</label>
              <input type="text" id="c-name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="c-email">Email</label>
              <input type="email" id="c-email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label for="c-whatsapp">WhatsApp</label>
              <input type="tel" id="c-whatsapp" name="whatsapp" placeholder="+41..." />
            </div>
            <div class="form-group">
              <label for="c-message">Message</label>
              <textarea id="c-message" name="message" placeholder="How can we help you?"></textarea>
            </div>
            <button type="submit" class="btn btn-red" style="width:100%">Order A Callback</button>
          </form>
        </div>

        <!-- Info -->
        <div class="contacts-info">
          <div class="info-block">
            <h3>Our Office</h3>
            <p>Baarerstrasse 135, 6300 Zug</p>
          </div>
          <div class="info-block">
            <h3>Phone</h3>
            <a href="tel:+41445152592">+41 44 51 52 592</a>
          </div>

          <div class="info-block">
            <h3>Working Hours</h3>
            <p>Monday — Friday: 09:00 — 18:00</p>
          </div>

          <!-- Map -->
          <div class="map-wrap">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2702.0!2d8.5150!3d47.1660!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x479aa0a33a5cfb0b%3A0x0!2sBaarerstrasse%20135%2C%206300%20Zug!5e0!3m2!1sen!2sch"
              width="100%" height="220" style="border:0;border-radius:12px" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"
              title="Morgan Hartley Consulting office location"></iframe>
          </div>

          <!-- Team -->
          <div class="contacts-person">
            <img src="/images/morgan-hartley-56.webp" alt="Morgan Hartley" width="64" height="64" class="contacts-avatar" />
            <div>
              <p class="contacts-name">Morgan Hartley</p>
              <p class="contacts-role">Morgan Hartley Consulting</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list" style="max-width:800px;margin:0 auto">
        <div class="faq-item">
          <button class="faq-question">What are your working hours?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Our offices in Zug are open Monday through Friday from 09:00 to 18:00 CET. You can also reach us outside business hours via our contact form.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How quickly do you respond to enquiries?</button>
          <div class="faq-answer"><div class="faq-answer-inner">We aim to respond to all enquiries within 24 hours on business days. For urgent matters, please call us directly at +41 44 51 52 592.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Do you offer consultations in languages other than English?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes, our team speaks English, German, French, and Russian. We can arrange consultations in your preferred language.</div></div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .contacts-lead {
    color: var(--gray-text);
    max-width: 560px;
    margin: 16px 0 48px;
  }
  .contacts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .info-block { margin-bottom: 24px; }
  .info-block h3 { font-size: 1rem; margin-bottom: 4px; }
  .info-block p, .info-block a { color: var(--gray-text); font-size: 0.95rem; }
  .info-block a:hover { color: var(--red); }

  .map-wrap {
    width: 100%;
    margin-bottom: 24px;
    border-radius: 12px;
    overflow: hidden;
  }
  .map-wrap iframe {
    display: block;
    width: 100%;
    height: 220px;
  }

  .contacts-person {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .contacts-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .contacts-name { font-weight: 700; }
  .contacts-role { color: var(--gray-text); font-size: 0.85rem; }

  @media (min-width: 768px) {
    .contacts-grid { grid-template-columns: 1fr 1fr; }
  }
</style>

<script>
document.querySelectorAll(".faq-question").forEach(btn => {
  btn.addEventListener("click", () => { btn.parentElement?.classList.toggle("active"); });
});
</script>
