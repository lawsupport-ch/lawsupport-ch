---
import Base from '../layouts/Base.astro';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Contacts — Lawsupport.ch",
    "description": "Get in touch with Lawsupport for corporate services and legal support in Switzerland.",
    "url": "https://lawsupport.ch/contacts/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" },
      { "@type": "ListItem", "position": 2, "name": "Contacts", "item": "https://lawsupport.ch/contacts/" }
    ]
  }
];
---

<Base title="Contacts — Lawsupport.ch" description="Get in touch with Lawsupport for corporate services and legal support in Switzerland." schema={schema}>

  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>Contacts</span>
    </nav>
  </div>

  <section class="section">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="contacts-lead">We are happy to help you with any questions regarding corporate services and legal support in Switzerland.</p>

      <div class="contacts-grid">
        <!-- Form -->
        <div class="contacts-form-wrap">
          <form class="contact-form" action="#" method="post">
            <div class="form-group">
              <label for="c-name">Name</label>
              <input type="text" id="c-name" name="name" placeholder="Your name" required />
            </div>
            <div class="form-group">
              <label for="c-email">Email</label>
              <input type="email" id="c-email" name="email" placeholder="your@email.com" required />
            </div>
            <div class="form-group">
              <label for="c-whatsapp">WhatsApp</label>
              <input type="tel" id="c-whatsapp" name="whatsapp" placeholder="+41..." />
            </div>
            <div class="form-group">
              <label for="c-message">Message</label>
              <textarea id="c-message" name="message" placeholder="How can we help you?"></textarea>
            </div>
            <button type="submit" class="btn btn-red" style="width:100%">Order A Callback</button>
          </form>
        </div>

        <!-- Info -->
        <div class="contacts-info">
          <div class="info-block">
            <h3>Our Office</h3>
            <p>Zurich, Switzerland</p>
          </div>
          <div class="info-block">
            <h3>Phone</h3>
            <a href="tel:+41445152590">+41 44 51 52 590</a>
          </div>
          <div class="info-block">
            <h3>Email</h3>
            <a href="mailto:info@lawsupport.ch">info@lawsupport.ch</a>
          </div>
          <div class="info-block">
            <h3>Working Hours</h3>
            <p>Monday — Friday: 09:00 — 18:00</p>
          </div>

          <!-- Map placeholder -->
          <div class="map-placeholder">
            <span>Map</span>
          </div>

          <!-- Team -->
          <div class="contacts-person">
            <div class="contacts-avatar"></div>
            <div>
              <p class="contacts-name">Morgan Hartley</p>
              <p class="contacts-role">Senior Corporate Lawyer &amp; Partner</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .contacts-lead {
    color: var(--gray-text);
    max-width: 560px;
    margin: 16px 0 48px;
  }
  .contacts-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .info-block { margin-bottom: 24px; }
  .info-block h3 { font-size: 1rem; margin-bottom: 4px; }
  .info-block p, .info-block a { color: var(--gray-text); font-size: 0.95rem; }
  .info-block a:hover { color: var(--red); }

  .map-placeholder {
    width: 100%;
    height: 220px;
    background: var(--gray);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--gray-text);
    font-size: 1.1rem;
    margin-bottom: 24px;
  }

  .contacts-person {
    display: flex;
    align-items: center;
    gap: 16px;
  }
  .contacts-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: #ddd;
    flex-shrink: 0;
  }
  .contacts-name { font-weight: 700; }
  .contacts-role { color: var(--gray-text); font-size: 0.85rem; }

  @media (min-width: 768px) {
    .contacts-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
