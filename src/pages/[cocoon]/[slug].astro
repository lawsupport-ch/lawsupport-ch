---
import { getCollection, render } from "astro:content";
import Article from "../../layouts/Article.astro";
import { getCocoon } from "../../lib/cocoon-map";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => {
    const cocoon = getCocoon(post.data.category);
    return {
      params: { cocoon, slug: post.id },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const cocoon = getCocoon(post.data.category);

const isScheduled = post.data.publishDate && new Date(post.data.publishDate) > new Date();
---

<Article
  title={post.data.title}
  description={post.data.description}
  category={post.data.category}
  categoryHref={`/${cocoon}/`}
  date={post.data.date}
  readTime={post.data.readTime}
  heroImage={post.data.heroImage}
  faqItems={post.data.faqItems}
  tocItems={post.data.tocItems}
  robots={isScheduled ? "noindex, follow" : undefined}
>
  <Content />
</Article>
