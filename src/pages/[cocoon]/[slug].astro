---
import { getCollection, render } from "astro:content";
import Article from "../../layouts/Article.astro";
import { getCocoon } from "../../lib/cocoon-map";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => (post.data.pageLevel || 3) !== 1)
    .map((post) => {
      const cocoon = getCocoon(post.data.category);
      return {
        params: { cocoon, slug: post.id },
        props: { post },
      };
    });
}

const { post } = Astro.props;
const { Content } = await render(post);
const cocoon = getCocoon(post.data.category);

const isScheduled = post.data.publishDate && new Date(post.data.publishDate) > new Date();

// Enrich relatedArticles with heroImage from linked posts
const allPosts = await getCollection("blog");
const enrichedRelated = (post.data.relatedArticles || []).map((ra: {title: string; href: string; image?: string}) => {
  if (ra.image) return ra;
  // Extract slug from href like /tax-accounting/accounting-switzerland/ → accounting-switzerland
  const slug = ra.href.replace(/\/$/, "").split("/").pop();
  const linked = allPosts.find((p) => p.id === slug);
  return { ...ra, image: linked?.data.heroImage || undefined };
});
---

<Article
  title={post.data.title}
  description={post.data.description}
  category={post.data.category}
  categoryHref={`/${cocoon}/`}
  date={post.data.date}
  readTime={post.data.readTime}
  heroImage={post.data.heroImage}
  dateModified={post.data.dateModified}
  faqItems={post.data.faqItems}
  tocItems={post.data.tocItems}
  relatedArticles={enrichedRelated}
  robots={isScheduled ? "noindex, follow" : undefined}
>
  <Content />
</Article>
