---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { COCOON_META, getCocoon } from '../../lib/cocoon-map';

export async function getStaticPaths() {
  return Object.keys(COCOON_META).map(cocoon => ({
    params: { cocoon },
    props: { cocoon },
  }));
}

const { cocoon } = Astro.props;
const meta = COCOON_META[cocoon];

const allPosts = await getCollection('blog', ({ data }) => {
  if (!data.publishDate) return true;
  return new Date(data.publishDate) <= new Date();
});

const cocoonPosts = allPosts.filter(post => getCocoon(post.data.category) === cocoon);

// Find L1 hub content for this cocoon
const hubPost = cocoonPosts.find(post => (post.data.pageLevel || 3) === 1);
let HubContent: any = null;
if (hubPost) {
  const rendered = await render(hubPost);
  HubContent = rendered.Content;
}

// Get L2 (Mixed) pages only for card grid
const l2Articles = cocoonPosts
  .filter(post => (post.data.pageLevel || 3) === 2)
  .sort((a, b) => {
    const dateA = a.data.date.split('.').reverse().join('-');
    const dateB = b.data.date.split('.').reverse().join('-');
    return dateB.localeCompare(dateA);
  })
  .map(post => ({
    title: post.data.title,
    href: `/${cocoon}/${post.id}/`,
    description: post.data.description,
  }));

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": meta.title,
    "url": `https://lawsupport.ch/${cocoon}/`
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" },
      { "@type": "ListItem", "position": 2, "name": meta.title, "item": `https://lawsupport.ch/${cocoon}/` }
    ]
  },
  ...(hubPost?.data.faqItems && hubPost.data.faqItems.length > 0 ? [{
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": hubPost.data.faqItems.map(f => ({
      "@type": "Question",
      "name": f.question,
      "acceptedAnswer": {"@type": "Answer", "text": f.answer}
    }))
  }] : [])
];
---

<Base title={`${meta.title} — Guides & Articles`} description={hubPost?.data.description || meta.description} schema={schema}>

  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>{meta.title}</span>
    </nav>
  </div>

  <!-- Article Hero -->
  <section class="article-hero">
    <div class="container">
      <div class="article-hero-grid">
        <div class="article-hero-content">
          <div class="article-meta">
            <span class="article-date">{hubPost?.data.date} &bull; {hubPost?.data.readTime}</span>
            <a href={`/${cocoon}/`} class="article-category">{meta.title}</a>
          </div>
          <h1>{meta.title}</h1>
          {hubPost?.data.description && <p class="article-desc">{hubPost.data.description}</p>}
        </div>
        <div class="article-hero-image">
          <div class="article-hero-placeholder"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Two-column: content + sidebar -->
  <section class="article-section">
    <div class="container">
      <div class="article-layout">
        <div class="article-content hub-content">
          {hubPost ? <HubContent /> : <p class="cocoon-lead">{meta.description}</p>}
        </div>
        <aside class="article-sidebar">
          {hubPost?.data.tocItems && hubPost.data.tocItems.length > 0 && (
            <div class="toc">
              <p class="sidebar-heading">Table of Contents</p>
              <ul>
                {hubPost.data.tocItems.map(item => (
                  <li><a href={`#${item.id}`}>{item.title}</a></li>
                ))}
              </ul>
            </div>
          )}
          <div class="sidebar-contact">
            <p class="sidebar-heading">Contact Us</p>
            <div class="sidebar-author">
              <img src="/images/morgan-hartley-56.webp" alt="Morgan Hartley" width="56" height="56" loading="lazy" class="sidebar-avatar" />
              <div class="sidebar-author-info">
                <p>Morgan Hartley</p>
                <span>Morgan Hartley Consulting</span>
              </div>
            </div>
            <p class="sidebar-tagline">Corporate and Tax lawyer in Switzerland</p>
            <div class="sidebar-contact-links">
              <a href="/contacts/" class="btn btn-red" style="padding:6px 16px;font-size:0.8rem;display:inline-block">Contact Us</a>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {hubPost?.data.faqItems && hubPost.data.faqItems.length > 0 && (
    <section class="section section-gray">
      <div class="container">
        <h2 class="section-title">FAQ</h2>
        <div class="faq-list">
          {hubPost.data.faqItems.map(item => (
            <div class="faq-item">
              <button class="faq-question">{item.question}</button>
              <div class="faq-answer">
                <div class="faq-answer-inner">{item.answer}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- L2 Cards: Explore by Topic -->
  {l2Articles.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">Explore by Topic</h2>
        <div class="grid-3">
          {l2Articles.map(article => (
            <a href={article.href} class="card l2-card">
              <div class="card-body">
                <h3>{article.title}</h3>
                <p class="l2-desc">{article.description}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
  .hub-content { line-height: 1.75; }
  .hub-content :global(h2) { margin-top: 48px; margin-bottom: 16px; font-size: 1.5rem; }
  .hub-content :global(h3) { margin-top: 32px; margin-bottom: 12px; font-size: 1.2rem; }
  .hub-content :global(p) { margin-bottom: 16px; color: var(--gray-text); }
  .hub-content :global(a) { color: var(--red); text-decoration: underline; }
  .hub-content :global(table) { width: 100%; border-collapse: collapse; margin: 24px 0; }
  .hub-content :global(th), .hub-content :global(td) { padding: 10px 14px; border: 1px solid #ddd; text-align: left; font-size: 0.9rem; }
  .hub-content :global(th) { background: #f5f5f5; font-weight: 600; }
  .hub-content :global(ul), .hub-content :global(ol) { margin: 16px 0; padding-left: 24px; }
  .hub-content :global(li) { margin-bottom: 8px; color: var(--gray-text); }
  .cocoon-lead { color: var(--gray-text); margin: 12px 0 40px; max-width: 700px; }
  .l2-card { border-left: 4px solid var(--red); }
  .l2-desc { font-size: 0.85rem; color: var(--gray-text); margin-top: 8px; }
  .section-title { margin-bottom: 32px; }
  .sidebar-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }
  .faq-list { max-width: 800px; margin: 0 auto; }
</style>

<script>
  document.querySelectorAll(".faq-question").forEach(btn => {
    btn.addEventListener("click", () => {
      const item = btn.parentElement;
      item?.classList.toggle("active");
    });
  });

  const tocLinks = document.querySelectorAll(".toc a");
  if (tocLinks.length > 0) {
    const headings = Array.from(tocLinks).map(link => {
      const id = link.getAttribute("href")?.slice(1);
      return id ? document.getElementById(id) : null;
    }).filter(Boolean) as HTMLElement[];

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          tocLinks.forEach(l => l.classList.remove("active"));
          const active = document.querySelector(`.toc a[href="#${entry.target.id}"]`);
          active?.classList.add("active");
        }
      });
    }, { rootMargin: "-80px 0px -60% 0px" });

    headings.forEach(h => observer.observe(h));
  }
</script>
