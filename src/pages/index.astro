---
import Base from '../layouts/Base.astro';

const services = [
  { title: 'Swiss Company Formation', href: '/company-formation/', color: 'red' },
  { title: 'Shelf Companies', href: '/company-formation/', color: 'white' },
  { title: 'Financial Licensing', href: '/licensing/', color: 'black' },
  { title: 'SECO Work Permits', href: '/immigration/', color: 'gray' },
  { title: 'Corporate Bank Account', href: '/banking/corporate-bank-account-switzerland/', color: 'red' },
  { title: 'Accounting In Switzerland', href: '/tax-accounting/accounting-switzerland/', color: 'white' },
  { title: 'Resident Card In Switzerland', href: '/immigration/b-permit-switzerland/', color: 'black' },
  { title: 'Company Liquidation In Switzerland', href: '/company-formation/company-liquidation-switzerland/', color: 'gray' },
];

const approachCards = [
  { title: 'Consultation', desc: 'We start by understanding your business objectives and requirements for establishing operations in Switzerland.', icon: '/icons/ourApproach/people.svg' },
  { title: 'Customised Strategy', desc: 'Our team develops a strategy aligned with Swiss standards and regulations, covering all legal and administrative aspects.', icon: '/icons/ourApproach/sign.svg' },
  { title: 'Execution', desc: 'We handle all administrative tasks, from company registration to bank account setup, ensuring a smooth process.', icon: '/icons/ourApproach/execution.svg' },
  { title: 'Ongoing Support', desc: 'After setup, we provide continuous guidance on compliance, accounting, and any legal matters that arise.', icon: '/icons/ourApproach/support.svg' },
];

const advantages = [
  { title: 'Strategic Location', desc: 'Switzerland sits at the heart of Europe, providing a gateway to multiple markets with excellent transport links, world-class infrastructure, and proximity to major financial centres. Businesses established here benefit from seamless access to the EU single market through bilateral agreements, while maintaining independence from EU regulations.', icon: '/icons/unlockSwissAdvantage/icon-1.svg', img: '/images/unlockSwissAdvantage/image-1.webp' },
  { title: 'Political Stability', desc: 'One of the most politically stable countries in the world, Switzerland offers a secure environment for your business. Its direct democracy, consensus-based governance, and long-standing neutrality create a predictable regulatory framework that protects investments and fosters long-term business planning with minimal political risk.', icon: '/icons/unlockSwissAdvantage/icon-2.svg', img: '/images/unlockSwissAdvantage/image-2.webp' },
  { title: 'Innovation Hub', desc: 'Home to world-class research institutions like ETH Zurich and EPFL, Switzerland consistently ranks as the most innovative country globally. A thriving startup ecosystem, generous R&D tax incentives, and strong intellectual property protection make it an ideal base for technology-driven enterprises seeking to push boundaries.', icon: '/icons/unlockSwissAdvantage/icon-3.svg', img: '/images/unlockSwissAdvantage/image-3.webp' },
  { title: 'Tax Benefits', desc: 'Competitive corporate tax rates — as low as 11.85% in the Canton of Zug — combined with an extensive network of double taxation treaties and favourable holding company regimes make Switzerland one of the most attractive jurisdictions for international businesses. Canton-level competition ensures ongoing tax optimisation opportunities.', icon: '/icons/unlockSwissAdvantage/icon-4.svg', img: '/images/unlockSwissAdvantage/image-4.webp' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Lawsupport — Swiss Corporate Services & Company Formation",
    "description": "Professional corporate services and legal support for businesses in Switzerland.",
    "url": "https://lawsupport.ch/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" }]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type": "Question", "name": "What types of companies can be formed in Switzerland?", "acceptedAnswer": {"@type": "Answer", "text": "The most common corporate forms are the AG (Aktiengesellschaft / corporation) with minimum capital of CHF 100,000 and the GmbH (Gesellschaft mit beschrankter Haftung / LLC) with minimum capital of CHF 20,000. Both offer limited liability and are suitable for different business sizes and structures."}},
      {"@type": "Question", "name": "How long does it take to form a Swiss company?", "acceptedAnswer": {"@type": "Answer", "text": "A standard AG or GmbH formation takes 2 to 4 weeks from initial consultation to commercial register entry. If you need to start immediately, we offer ready-made shelf companies that can be transferred within 5 business days."}},
      {"@type": "Question", "name": "Do I need to be a Swiss resident to own a Swiss company?", "acceptedAnswer": {"@type": "Answer", "text": "No, foreign nationals can fully own a Swiss AG or GmbH. However, at least one director must be a Swiss resident with signing authority. We provide nominee director services to meet this requirement."}},
      {"@type": "Question", "name": "What are the corporate tax rates in Switzerland?", "acceptedAnswer": {"@type": "Answer", "text": "Corporate tax rates vary by canton. The Canton of Zug offers one of the lowest rates at approximately 11.85%. Zurich is around 19.7%. We help clients choose the optimal canton based on their business model, industry, and tax planning goals."}},
      {"@type": "Question", "name": "Can you help with obtaining work permits and residence cards?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, we assist with B and C residence permits, cross-border permits (G), and work permits for non-EU nationals. The process typically takes 4 to 8 weeks depending on the permit type and cantonal authorities involved."}}
    ]
  }
];
---

<Base title="Lawsupport — Swiss Corporate Services & Company Formation" description="Swiss corporate services by experienced lawyers: company formation, shelf companies, bank accounts, residence permits. Offices in Zurich and Zug. Free consultation." schema={schema}>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content container">
      <h1>Business In Switzerland</h1>
      <p>And company registration<br/>in Switzerland</p>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="service-cards">
    {services.map(s => (
      <a href={s.href} class={`service-card service-card--${s.color}`}>
        <span>{s.title}</span>
      </a>
    ))}
  </section>

  <!-- Why Choose + Approach Cards -->
  <section class="section">
    <div class="container">
      <div class="why-top">
        <div class="why-left">
          <h2>Why <span class="text-red">Lawsupport</span></h2>
          <p>We are a team of experienced Swiss lawyers specialising in corporate law and business advisory. From company formation to ongoing compliance, we handle every aspect of your Swiss business journey with precision and care.</p>
        </div>
        <div class="why-right">
          <p>Every business is unique. Whether you are a startup founder looking to establish your first European entity, or a multinational expanding into Switzerland, we develop a custom approach aligned with your specific needs and Swiss standards. Our offices in Zurich and Zug give us direct access to the two most business-friendly cantons in the country.</p>
        </div>
      </div>
      <div class="approach-grid">
        {approachCards.map(card => (
          <div class="approach-card">
            <img src={card.icon} alt={card.title} width="48" height="48" loading="lazy" />
            <h3>{card.title}</h3>
            <p>{card.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Swiss Advantage -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">Unlock the Swiss Advantage</h2>
      <div class="advantage-stack">
        {advantages.map((adv, i) => (
          <div class={`advantage-block ${i % 2 === 1 ? 'advantage-block--reverse' : ''}`}>
            <div class="advantage-block-img">
              <img src={adv.img} alt={adv.title} width="700" height="400" loading="lazy" />
            </div>
            <div class="advantage-block-content">
              <div class="advantage-block-icon">
                <img src={adv.icon} alt={adv.title + " icon"} width="40" height="40" />
              </div>
              <h3>{adv.title}</h3>
              <p>{adv.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Insight / Blog -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Insight</h2>
      <div class="insight-grid">
        <a href="/company-formation/ag-formation-switzerland/" class="insight-card">
          <img src="/images/blog/ag-formation.webp" alt="AG Formation in Switzerland" loading="lazy" />
          <h3>AG Formation in Switzerland: Complete Step-by-Step Guide</h3>
        </a>
        <a href="/blog/" class="insight-card">
          <img src="/images/blog/company-formation.webp" alt="Company Formation" loading="lazy" />
          <h3>How to Register a Company in Switzerland as a Foreigner</h3>
        </a>
        <a href="/blog/" class="insight-card">
          <img src="/images/blog/swiss-bank.webp" alt="Swiss Bank Account" loading="lazy" />
          <h3>Opening a Swiss Bank Account for Your Business</h3>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-gray" id="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list" style="max-width:800px;margin:0 auto">
        <div class="faq-item">
          <button class="faq-question">What types of companies can be formed in Switzerland?</button>
          <div class="faq-answer"><div class="faq-answer-inner">The most common corporate forms are the AG (Aktiengesellschaft / corporation) with minimum capital of CHF 100,000 and the GmbH (Gesellschaft mit beschrankter Haftung / LLC) with minimum capital of CHF 20,000. Both offer limited liability and are suitable for different business sizes and structures.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How long does it take to form a Swiss company?</button>
          <div class="faq-answer"><div class="faq-answer-inner">A standard AG or GmbH formation takes 2 to 4 weeks from initial consultation to commercial register entry. If you need to start immediately, we offer ready-made shelf companies that can be transferred within 5 business days.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Do I need to be a Swiss resident to own a Swiss company?</button>
          <div class="faq-answer"><div class="faq-answer-inner">No, foreign nationals can fully own a Swiss AG or GmbH. However, at least one director must be a Swiss resident with signing authority. We provide nominee director services to meet this requirement.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">What are the corporate tax rates in Switzerland?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Corporate tax rates vary by canton. The Canton of Zug offers one of the lowest rates at approximately 11.85%. Zurich is around 19.7%. We help clients choose the optimal canton based on their business model, industry, and tax planning goals.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Can you help with obtaining work permits and residence cards?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes, we assist with B and C residence permits, cross-border permits (G), and work permits for non-EU nationals. The process typically takes 4 to 8 weeks depending on the permit type and cantonal authorities involved.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section section-gray" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Contact us</h2>
          <div class="contact-person-large">
            <img src="/images/morgan-hartley.jpg" alt="Morgan Hartley" width="400" height="500" class="contact-photo" loading="lazy" />
            <div class="contact-person-details">
              <p class="contact-name"><a href="/team/morgan-hartley/" style="color:inherit">Morgan Hartley</a></p>
              <p class="contact-role">Lawyer</p>
              <div class="contact-details">
                <a href="tel:+41445152592"><img src="/icons/tel.svg" alt="Phone" width="18" height="18" /> +41 44 51 52 592</a>
              </div>
              <a href="#contact" class="btn btn-red contact-callback-btn">Order A Callback</a>
            </div>
          </div>
        </div>
        <form class="contact-form" action="#" method="post">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="whatsapp">WhatsApp</label>
            <input type="tel" id="whatsapp" name="whatsapp" placeholder="+41..." />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="btn btn-red" style="width:100%">Order A Callback</button>
        </form>
      </div>
    </div>
  </section>

</Base>

<style>
  /* Hero */
  .hero {
    background: var(--red);
    color: var(--white);
    padding: 60px 0;
  }
  .hero-content {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 20px;
  }
  .hero-content h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    margin-bottom: 8px;
    font-weight: 800;
  }
  .hero-content p {
    font-size: clamp(1rem, 2.5vw, 1.3rem);
    opacity: 0.8;
    line-height: 1.5;
  }

  /* Service Cards */
  .service-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
  }
  .service-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 28px 16px;
    font-weight: 600;
    font-size: 0.85rem;
    transition: opacity 0.2s;
    min-height: 80px;
  }
  .service-card:hover { opacity: 0.85; }
  .service-card--red { background: var(--red); color: var(--white); }
  .service-card--black { background: var(--black); color: var(--white); }
  .service-card--gray { background: var(--gray); color: var(--black); }
  .service-card--white { background: var(--white); color: var(--black); border: 1px solid #e5e5e5; }

  .text-red { color: var(--red); }

  /* Why Choose */
  .why-top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-bottom: 48px;
  }
  .why-left h2 {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    margin-bottom: 16px;
  }
  .why-left p, .why-right p {
    color: var(--gray-text);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .approach-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .approach-card {
    text-align: center;
    padding: 24px 16px;
    background: var(--white);
    border-radius: 12px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .approach-card img { margin-bottom: 16px; }
  .approach-card h3 { font-size: 1rem; margin-bottom: 8px; }
  .approach-card p { color: var(--gray-text); font-size: 0.85rem; line-height: 1.6; }

  /* Swiss Advantage */
  .advantage-stack {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }
  .advantage-block {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    align-items: center;
  }
  .advantage-block-img {
    border-radius: 12px;
    overflow: hidden;
  }
  .advantage-block-img img {
    width: 100%;
    height: 100%;
    min-height: 220px;
    object-fit: cover;
    display: block;
  }
  .advantage-block-icon {
    margin-bottom: 12px;
  }
  .advantage-block-content h3 {
    font-size: 1.3rem;
    margin-bottom: 12px;
  }
  .advantage-block-content p {
    color: var(--gray-text);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  /* Insight / Blog */
  .insight-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }
  .insight-card {
    border-radius: 12px;
    overflow: hidden;
    background: var(--white);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
  }
  .insight-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
  }
  .insight-card img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    display: block;
  }
  .insight-card h3 {
    padding: 16px;
    font-size: 1rem;
    line-height: 1.4;
  }

  /* Contact */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .contact-info h2 { margin-bottom: 24px; }
  .contact-person-large {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .contact-photo {
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: 12px;
    object-fit: cover;
  }
  .contact-person-details {}
  .contact-name { font-weight: 700; font-size: 1.2rem; margin-bottom: 4px; }
  .contact-role { color: var(--gray-text); font-size: 0.9rem; margin-bottom: 16px; }
  .contact-details { display: flex; flex-direction: column; gap: 8px; margin-bottom: 20px; }
  .contact-details a { font-weight: 500; display: flex; align-items: center; gap: 8px; font-size: 1rem; }
  .contact-details a:hover { color: var(--red); }
  .contact-callback-btn {
    display: inline-block;
    padding: 12px 28px;
    font-size: 0.95rem;
  }

  /* FAQ */
  .faq-list { display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 1px solid #e0e0e0; }
  .faq-question {
    width: 100%; background: none; border: none; padding: 20px 0;
    font-size: 1.05rem; font-weight: 600; text-align: left; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    font-family: inherit; color: inherit;
  }
  .faq-question::after { content: "+"; font-size: 1.4rem; font-weight: 300; transition: transform 0.2s; }
  .faq-item.active .faq-question::after { content: "\2212"; }
  .faq-answer { max-height: none; }
  
  .faq-answer-inner { padding: 0 0 20px; color: var(--gray-text); font-size: 0.95rem; line-height: 1.7; }

  /* Responsive */
  @media (min-width: 480px) {
    .insight-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 768px) {
    .hero { padding: 80px 0; }
    .hero-content h1 { font-size: 3rem; }

    .service-cards { grid-template-columns: repeat(4, 1fr); }

    .why-top { grid-template-columns: 1fr 1fr; gap: 48px; }

    .approach-grid { grid-template-columns: repeat(4, 1fr); }

    .advantage-block { grid-template-columns: 1fr 1fr; }
    .advantage-block--reverse .advantage-block-img { order: 2; }
    .advantage-block--reverse .advantage-block-content { order: 1; }

    .insight-grid { grid-template-columns: repeat(3, 1fr); }

    .contact-grid { grid-template-columns: 1fr 1fr; }
    .contact-person-large { flex-direction: column; }
    .contact-photo { max-width: 100%; }
  }

  @media (min-width: 1024px) {
    .hero { padding: 100px 0; }
    .advantage-block-img img { min-height: 300px; }
  }
</style>
<script>
document.querySelectorAll(".faq-question").forEach(btn => {
  btn.addEventListener("click", () => {
    btn.parentElement?.classList.toggle("active");
  });
});
</script>
