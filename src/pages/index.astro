---
import Base from '../layouts/Base.astro';

const services = [
  { title: 'Resident card in Switzerland', href: '/resident-card-in-switzerland/', color: 'red' },
  { title: 'Swiss company formation', href: '/swiss-company-formation/', color: 'gray' },
  { title: 'Business in Switzerland', href: '/business-in-switzerland/', color: 'black' },
  { title: 'Accounting in Switzerland', href: '/accounting-in-switzerland/', color: 'red' },
  { title: 'Company liquidation', href: '/company-liquidation-in-switzerland/', color: 'black' },
  { title: 'Shelf company in Switzerland', href: '/shelf-company-in-switzerland/', color: 'gray' },
  { title: 'Migration to Switzerland', href: '/migration-to-switzerland/', color: 'red' },
  { title: 'Swiss bank account', href: '/swiss-bank-account/', color: 'black' },
];

const whyChoose = [
  { title: 'Expertise in Swiss Corporate Law', desc: 'Our team of experienced Swiss lawyers specialises in corporate law, ensuring your business is set up correctly from the start.', img: '/images/expertiseAndServices/write.webp' },
  { title: 'Efficient Company Formation', desc: 'We provide seamless and efficient company formation services, handling all administrative and legal requirements.', img: '/images/expertiseAndServices/show.webp' },
  { title: 'Shelf Companies Available', desc: 'Need to start quickly? We offer ready-made shelf companies for an expedited business launch in Switzerland.', img: '/images/expertiseAndServices/flag.webp' },
  { title: 'Resident Card Assistance', desc: 'We assist with obtaining resident cards and work permits, helping you establish a physical presence in Switzerland.', img: '/images/expertiseAndServices/citi.webp' },
  { title: 'Swiss Bank Account Setup', desc: 'We help you open Swiss bank accounts, ensuring your financial management is properly structured.', img: '/images/expertiseAndServices/notebook.webp' },
  { title: 'Accounting Services', desc: 'Professional financial record management and accounting services to keep your Swiss business compliant.', img: '/images/expertiseAndServices/build.webp' },
  { title: 'Company Liquidation Support', desc: 'When needed, we provide expert support for company dissolution, ensuring all legal obligations are met.', img: '/images/expertiseAndServices/bark.webp' },
  { title: 'Personalised Approach', desc: 'Every business is unique. We develop custom approaches aligned with your specific needs and Swiss standards.', img: '/images/expertiseAndServices/speack.webp' },
];

const steps = [
  { num: '01', title: 'Consultation', desc: 'We start by understanding your business objectives and requirements for establishing operations in Switzerland.', icon: '/icons/ourApproach/people.svg' },
  { num: '02', title: 'Customised Strategy', desc: 'Our team develops a strategy aligned with Swiss standards and regulations, covering all legal and administrative aspects.', icon: '/icons/ourApproach/sign.svg' },
  { num: '03', title: 'Execution', desc: 'We handle all administrative tasks, from company registration to bank account setup, ensuring a smooth process.', icon: '/icons/ourApproach/execution.svg' },
  { num: '04', title: 'Ongoing Support', desc: 'After setup, we provide continuous guidance on compliance, accounting, and any legal matters that arise.', icon: '/icons/ourApproach/support.svg' },
];

const advantages = [
  { title: 'Strategic Location', desc: 'Switzerland sits at the heart of Europe, providing a gateway to multiple markets with excellent infrastructure.', icon: '/icons/unlockSwissAdvantage/icon-1.svg', img: '/images/unlockSwissAdvantage/image-1.webp' },
  { title: 'Political Stability', desc: 'One of the most politically stable countries in the world, offering a secure environment for your business.', icon: '/icons/unlockSwissAdvantage/icon-2.svg', img: '/images/unlockSwissAdvantage/image-2.webp' },
  { title: 'Innovation Hub', desc: 'Home to world-class research institutions and a thriving startup ecosystem that fosters innovation.', icon: '/icons/unlockSwissAdvantage/icon-3.svg', img: '/images/unlockSwissAdvantage/image-3.webp' },
  { title: 'Tax Benefits', desc: 'Competitive tax rates and favourable treaties make Switzerland an attractive destination for businesses worldwide.', icon: '/icons/unlockSwissAdvantage/icon-4.svg', img: '/images/unlockSwissAdvantage/image-4.webp' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Lawsupport — Swiss Corporate Services & Company Formation",
    "description": "Professional corporate services and legal support for businesses in Switzerland.",
    "url": "https://lawsupport.ch/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [{ "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" }]
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {"@type": "Question", "name": "What types of companies can be formed in Switzerland?", "acceptedAnswer": {"@type": "Answer", "text": "The most common corporate forms are the AG (Aktiengesellschaft / corporation) with minimum capital of CHF 100,000 and the GmbH (Gesellschaft mit beschrankter Haftung / LLC) with minimum capital of CHF 20,000. Both offer limited liability and are suitable for different business sizes and structures."}},
      {"@type": "Question", "name": "How long does it take to form a Swiss company?", "acceptedAnswer": {"@type": "Answer", "text": "A standard AG or GmbH formation takes 2 to 4 weeks from initial consultation to commercial register entry. If you need to start immediately, we offer ready-made shelf companies that can be transferred within 5 business days."}},
      {"@type": "Question", "name": "Do I need to be a Swiss resident to own a Swiss company?", "acceptedAnswer": {"@type": "Answer", "text": "No, foreign nationals can fully own a Swiss AG or GmbH. However, at least one director must be a Swiss resident with signing authority. We provide nominee director services to meet this requirement."}},
      {"@type": "Question", "name": "What are the corporate tax rates in Switzerland?", "acceptedAnswer": {"@type": "Answer", "text": "Corporate tax rates vary by canton. The Canton of Zug offers one of the lowest rates at approximately 11.85%. Zurich is around 19.7%. We help clients choose the optimal canton based on their business model, industry, and tax planning goals."}},
      {"@type": "Question", "name": "Can you help with obtaining work permits and residence cards?", "acceptedAnswer": {"@type": "Answer", "text": "Yes, we assist with B and C residence permits, cross-border permits (G), and work permits for non-EU nationals. The process typically takes 4 to 8 weeks depending on the permit type and cantonal authorities involved."}}
    ]
  }
];
---

<Base title="Lawsupport — Swiss Corporate Services & Company Formation" description="Swiss corporate services by experienced lawyers: company formation, shelf companies, bank accounts, residence permits. Offices in Zurich and Zug. Free consultation." schema={schema}>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-content">
      <div class="hero-text">
        <h1>Swiss Corporate Services & Company Formation</h1>
        <p>Legal support for your business in Switzerland</p>
      </div>
      <div class="hero-image">
        <img src="/images/lawsupport.webp" alt="Business in Switzerland" width="800" height="600" />
      </div>
    </div>
  </section>

  <!-- Service Cards -->
  <section class="service-cards">
    {services.map(s => (
      <a href={s.href} class={`service-card service-card--${s.color}`}>
        <span>{s.title}</span>

      </a>
    ))}
  </section>

  <!-- Why Choose -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Why Choose <span class="text-red">Lawsupport</span> for<br/>Your Swiss Business Needs</h2>
      <div class="grid-2 why-grid">
        {whyChoose.map(item => (
          <div class="why-card">
            <div class="why-card-img">
              <img src={item.img} alt={item.title} width="350" height="350" loading="lazy" />
            </div>
            <div class="why-card-content">
              <h3>{item.title}</h3>
              <p>{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Our Approach — 4 Steps -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">Our approach</h2>
      <div class="steps-grid">
        {steps.map(step => (
          <div class="step-card">
            <img src={step.icon} alt={step.title} width="56" height="56" class="step-icon" loading="lazy" />
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Swiss Advantage -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Unlock the Swiss Advantage</h2>
      <div class="grid-4 advantage-grid">
        {advantages.map(adv => (
          <div class="advantage-card">
            <div class="advantage-img">
              <img src={adv.img} alt={adv.title} width="700" height="209" loading="lazy" />
            </div>
            <div class="advantage-icon">
              <img src={adv.icon} alt="" width="32" height="32" />
            </div>
            <h3>{adv.title}</h3>
            <p>{adv.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Join Our Success Stories -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">Join Our Success Stories</h2>
      <p class="stories-text">Over the years, we have helped hundreds of entrepreneurs and businesses establish and grow their presence in Switzerland. From company formation to bank account setup, our clients trust us to handle the complexities of Swiss corporate law so they can focus on what matters most — their business.</p>
      <div class="stories-stats">
        <div class="stat-item">
          <span class="stat-number">500+</span>
          <span class="stat-label">Companies formed</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">15+</span>
          <span class="stat-label">Years of experience</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">98%</span>
          <span class="stat-label">Client satisfaction</span>
        </div>
      </div>
    </div>
  </section>


  <!-- FAQ -->
  <section class="section section-gray" id="faq">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list" style="max-width:800px;margin:0 auto">
        <div class="faq-item">
          <button class="faq-question">What types of companies can be formed in Switzerland?</button>
          <div class="faq-answer"><div class="faq-answer-inner">The most common corporate forms are the AG (Aktiengesellschaft / corporation) with minimum capital of CHF 100,000 and the GmbH (Gesellschaft mit beschrankter Haftung / LLC) with minimum capital of CHF 20,000. Both offer limited liability and are suitable for different business sizes and structures.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How long does it take to form a Swiss company?</button>
          <div class="faq-answer"><div class="faq-answer-inner">A standard AG or GmbH formation takes 2 to 4 weeks from initial consultation to commercial register entry. If you need to start immediately, we offer ready-made shelf companies that can be transferred within 5 business days.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Do I need to be a Swiss resident to own a Swiss company?</button>
          <div class="faq-answer"><div class="faq-answer-inner">No, foreign nationals can fully own a Swiss AG or GmbH. However, at least one director must be a Swiss resident with signing authority. We provide nominee director services to meet this requirement.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">What are the corporate tax rates in Switzerland?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Corporate tax rates vary by canton. The Canton of Zug offers one of the lowest rates at approximately 11.85%. Zurich is around 19.7%. We help clients choose the optimal canton based on their business model, industry, and tax planning goals.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Can you help with obtaining work permits and residence cards?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes, we assist with B and C residence permits, cross-border permits (G), and work permits for non-EU nationals. The process typically takes 4 to 8 weeks depending on the permit type and cantonal authorities involved.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section class="section section-gray" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-info">
          <h2>Contact us</h2>
          <div class="contact-person">
            <img src="/images/morgan-hartley-56.webp" alt="Morgan Hartley" width="80" height="80" class="contact-avatar" />
            <div>
              <p class="contact-name">Morgan Hartley</p>
              <p class="contact-role">Senior Corporate Lawyer &amp; Partner</p>
            </div>
          </div>
          <div class="contact-details">
            <a href="tel:+41445152590"><img src="/icons/tel.svg" alt="" width="18" height="18" /> +41 44 51 52 590</a>
            <a href="mailto:info@lawsupport.ch"><img src="/icons/massage.svg" alt="" width="18" height="18" /> info@lawsupport.ch</a>
          </div>
        </div>
        <form class="contact-form" action="#" method="post">
          <div class="form-group">
            <label for="name">Name</label>
            <input type="text" id="name" name="name" placeholder="Your name" required />
          </div>
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="your@email.com" required />
          </div>
          <div class="form-group">
            <label for="whatsapp">WhatsApp</label>
            <input type="tel" id="whatsapp" name="whatsapp" placeholder="+41..." />
          </div>
          <div class="form-group">
            <label for="message">Message</label>
            <textarea id="message" name="message" placeholder="How can we help you?"></textarea>
          </div>
          <button type="submit" class="btn btn-red" style="width:100%">Order A Callback</button>
        </form>
      </div>
    </div>
  </section>

</Base>

<style>
  .hero {
    background: var(--red);
    color: var(--white);
  }
  .hero-content {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    min-height: 400px;
  }
  .hero-text {
    padding: 60px 20px 40px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }
  .hero-text h1 { font-size: clamp(1.8rem, 5vw, 2.5rem); margin-bottom: 12px; }
  .hero-text p { font-size: 1.1rem; opacity: 0.9; }
  .hero-image { position: relative; overflow: hidden; }
  .hero-image img {
    width: 100%;
    height: 100%;
    min-height: 250px;
    object-fit: cover;
  }

  .service-cards {
    display: grid;
    grid-template-columns: 1fr;
  }
  .service-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 24px 20px;
    font-weight: 600;
    font-size: 0.85rem;
    transition: opacity 0.2s;
  }
  .service-card:hover { opacity: 0.85; }
  .service-card--red { background: var(--red); color: var(--white); }
  .service-card--black { background: var(--black); color: var(--white); }
  .service-card--gray { background: var(--gray); color: var(--black); }
  .service-card--white { background: var(--white); color: var(--black); }

  .text-red { color: var(--red); }

  .why-card {
    display: grid;
    grid-template-columns: 1fr;
    border-radius: 12px;
    overflow: hidden;
    background: var(--white);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }
  .why-card:nth-child(even) .why-card-img { order: 2; }
  .why-card:nth-child(even) .why-card-content { order: 1; }
  .why-card-img { min-height: 200px; overflow: hidden; }
  .why-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .why-card-content { padding: 24px; }
  .why-card-content h3 { font-size: 1.1rem; margin-bottom: 8px; }
  .why-card-content p { color: var(--gray-text); font-size: 0.9rem; }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }
  .step-card { text-align: center; padding: 32px 16px; }
  .step-icon {
    margin-bottom: 20px;
  }
  .step-card h3 { font-size: 1.1rem; margin-bottom: 8px; }
  .step-card p { color: var(--gray-text); font-size: 0.9rem; }

  .advantage-card { text-align: center; padding: 0; border-radius: 12px; overflow: hidden; background: var(--white); box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
  .advantage-img { height: 160px; overflow: hidden; }
  .advantage-img img { width: 100%; height: 100%; object-fit: cover; }
  .advantage-icon { margin: 16px 0 8px; }
  .advantage-card h3 { font-size: 1.1rem; margin-bottom: 8px; padding: 0 16px; }
  .advantage-card p { color: var(--gray-text); font-size: 0.9rem; padding: 0 16px 24px; }

  .stories-text {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 48px;
    color: var(--gray-text);
    font-size: 1rem;
    line-height: 1.7;
  }
  .stories-stats {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .stat-item { text-align: center; }
  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--red);
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 0.9rem;
    color: var(--gray-text);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .contact-info h2 { margin-bottom: 24px; }
  .contact-person {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }
  .contact-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .contact-name { font-weight: 700; font-size: 1.1rem; }
  .contact-role { color: var(--gray-text); font-size: 0.9rem; }
  .contact-details { display: flex; flex-direction: column; gap: 8px; }
  .contact-details a { font-weight: 500; display: flex; align-items: center; gap: 8px; }
  .contact-details a:hover { color: var(--red); }

  @media (min-width: 480px) {
    .service-cards { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 640px) {
    .steps-grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (min-width: 768px) {
    .hero-content { grid-template-columns: 1fr 1fr; }
    .hero-text h1 { font-size: 3.5rem; }
    .service-cards { grid-template-columns: repeat(4, 1fr); }
    .why-card-img { min-height: 220px; }
    .stories-text {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 48px;
    color: var(--gray-text);
    font-size: 1rem;
    line-height: 1.7;
  }
  .stories-stats {
    display: flex;
    justify-content: center;
    gap: 32px;
    flex-wrap: wrap;
  }
  .stat-item { text-align: center; }
  .stat-number {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    color: var(--red);
    margin-bottom: 4px;
  }
  .stat-label {
    font-size: 0.9rem;
    color: var(--gray-text);
  }

  .contact-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .hero-text { padding: 80px 40px; }
    .hero-text h1 { font-size: 4rem; }
  }

  .faq-list { display: flex; flex-direction: column; gap: 0; }
  .faq-item { border-bottom: 1px solid #e0e0e0; }
  .faq-question {
    width: 100%; background: none; border: none; padding: 20px 0;
    font-size: 1.05rem; font-weight: 600; text-align: left; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    font-family: inherit; color: inherit;
  }
  .faq-question::after { content: "+"; font-size: 1.4rem; font-weight: 300; transition: transform 0.2s; }
  .faq-item.active .faq-question::after { content: "\2212"; }
  .faq-answer { max-height: 0; overflow: hidden; transition: max-height 0.3s ease; }
  .faq-item.active .faq-answer { max-height: 300px; }
  .faq-answer-inner { padding: 0 0 20px; color: var(--gray-text); font-size: 0.95rem; line-height: 1.7; }
</style>
<script>
document.querySelectorAll(".faq-question").forEach(btn => {
  btn.addEventListener("click", () => {
    btn.parentElement?.classList.toggle("active");
  });
});
</script>
