---
import Base from '../layouts/Base.astro';

const services = [
  { name: 'Company Formation', href: '/company-formation/' },
  { name: 'Shelf Companies', href: '/company-formation/' },
  { name: 'Financial Licensing', href: '/licensing/' },
  { name: 'SECO Work Permits', href: '/immigration/' },
  { name: 'Company Liquidation', href: null },
  { name: 'Business Restructuring', href: null },
  { name: 'Tax Registration & Tax Returns', href: null },
  { name: 'Legal Representation', href: null },
  { name: 'Business Plan Consulting', href: null },
  { name: 'Accounting & Auditing', href: null },
  { name: 'Nominee Directors & Shareholders', href: null },
  { name: 'IP Protection & Trademarks', href: null },
  { name: 'Real Estate & Property', href: null },
  { name: 'Immigration & Residence Permits', href: null },
  { name: 'Swiss Bank Account Opening', href: null },
  { name: 'Crypto & Blockchain Licensing', href: null },
  { name: 'Labour Law & Employment', href: null },
  { name: 'Mergers & Acquisitions', href: null },
  { name: 'Due Diligence', href: null },
  { name: 'Compliance & Regulatory', href: null },
  { name: 'Contract Drafting & Review', href: null },
  { name: 'Corporate Governance', href: null },
  { name: 'Debt Collection', href: null },
];

const howItWorks = [
  { num: '01', title: 'Initial Consultation', desc: 'We assess your situation, understand your goals and outline the best path forward for your Swiss business needs.' },
  { num: '02', title: 'Strategy and Planning', desc: 'Our experts develop a detailed plan covering legal, tax and operational aspects aligned with Swiss regulations.' },
  { num: '03', title: 'Documentation and Support', desc: 'We prepare all necessary documents, handle submissions to authorities and keep you informed at every step.' },
  { num: '04', title: 'Completion and Follow-up', desc: 'Once your matter is resolved, we provide ongoing support to ensure continued compliance and success.' },
];

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "About Lawsupport — Swiss Corporate Law Firm in Zurich & Zug",
    "description": "Meet our team of international legal experts offering services for company formation, tax consulting, and more in Switzerland.",
    "url": "https://lawsupport.ch/about/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" },
      { "@type": "ListItem", "position": 2, "name": "About Us", "item": "https://lawsupport.ch/about/" }
    ]
  }
];
---

<Base title="About Lawsupport — Swiss Corporate Law Firm in Zurich & Zug" description="Meet our team of international legal experts offering services for company formation, tax consulting, and more in Switzerland." schema={schema}>

  <!-- Breadcrumb -->
  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>About Us</span>
    </nav>
  </div>

  <!-- Hero -->
  <section class="about-hero section">
    <div class="container">
      <div class="about-hero-grid">
        <div>
          <h1>About Lawsupport</h1>
          <p class="about-lead">Lawsupport is a team of international legal experts offering services for company formation, tax consulting, and more. Trust us for your legal needs.</p>
          <div class="about-countries">
            <h4>We working in these countries</h4>
            <div class="country-tags">
              <span>Switzerland</span>
              <span>Cyprus</span>
              <span>Germany</span>
              <span>Hong Kong</span>
              <span>United Kingdom</span>
            </div>
          </div>
          <a href="/contacts/" class="btn btn-red">Contact us</a>
          <a href="/team/morgan-hartley/" class="btn btn-outline" style="margin-left:12px">Meet Our Team</a>
        </div>
        <div class="about-hero-image">
          <img src="/images/morgan-hartley-56.webp" alt="Morgan Hartley — Senior Corporate Lawyer" width="964" height="987" class="about-hero-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- What We Do -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">What We Do</h2>
      <div class="services-grid">
        {services.map((s, i) => (
          <div class="service-item">
            <span class="service-num">{String(i + 1).padStart(2, '0')}</span>
            {s.href ? <a href={s.href} class="service-name service-name--linked">{s.name}</a> : <span class="service-name">{s.name}</span>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section">
    <div class="container">
      <h2 class="section-title">How it Works</h2>
      <div class="grid-4">
        {howItWorks.map(step => (
          <div class="hiw-card">
            <span class="hiw-num">{step.num}</span>
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section-gray">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list" style="max-width:800px;margin:0 auto">
        <div class="faq-item">
          <button class="faq-question">What countries does Lawsupport operate in?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Our primary focus is Switzerland, with offices in Zurich and Zug. We also assist clients with corporate matters in Germany, Cyprus, Hong Kong, and the United Kingdom through our partner network.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">How many companies has Lawsupport formed?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Since 2003, we have assisted in forming over 500 companies in Switzerland, including AGs, GmbHs, and branch offices of foreign corporations.</div></div>
        </div>
        <div class="faq-item">
          <button class="faq-question">Do you offer free initial consultations?</button>
          <div class="faq-answer"><div class="faq-answer-inner">Yes, we provide a free 30-minute initial consultation to understand your needs and outline the best path forward. You can book a consultation through our contact page or call us directly.</div></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section class="section">
    <div class="container">
      <div class="about-contact-grid">
        <div>
          <h2>Contact us</h2>
          <div class="contact-person">
            <img src="/images/morgan-hartley-56.webp" alt="Morgan Hartley" width="80" height="80" class="contact-avatar" />
            <div>
              <p class="contact-name"><a href="/team/morgan-hartley/" style="color:inherit">Morgan Hartley</a></p>
              <p class="contact-role">Senior Corporate Lawyer &amp; Partner, Lawsupport.ch</p>
            </div>
          </div>
          <div class="contact-details">
            <a href="tel:+41445152592">+41 44 51 52 592</a>
            <a href="/contacts/" class="btn btn-red" style="margin-top:8px;display:inline-block;padding:10px 24px;font-size:0.85rem">Contact Us</a>
          </div>
        </div>
        <div class="about-contact-image">
          <img src="/images/lawsupport.webp" alt="Lawsupport office" width="789" height="387" class="about-contact-img" />
        </div>
      </div>
    </div>
  </section>

</Base>

<style>
  .about-hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  .about-lead {
    color: var(--gray-text);
    font-size: 1.05rem;
    margin: 16px 0 32px;
    max-width: 520px;
  }
  .about-countries { margin-bottom: 32px; }
  .about-countries h4 { font-size: 0.9rem; margin-bottom: 12px; color: var(--gray-text); }
  .country-tags { display: flex; flex-wrap: wrap; gap: 8px; }
  .country-tags span {
    padding: 6px 14px;
    border: 1px solid var(--gray-border);
    border-radius: 20px;
    font-size: 0.85rem;
  }
  .about-hero-img {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 12px;
  }

  /* Services grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 16px;
  }
  .service-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px;
    background: var(--white);
    border-radius: 8px;
    font-size: 0.9rem;
  }
  .service-num {
    color: var(--red);
    font-weight: 700;
    font-size: 0.8rem;
    flex-shrink: 0;
  }
  .service-name { font-weight: 500; }
  .service-name--linked { color: var(--red); text-decoration: underline; }
  .service-name--linked:hover { text-decoration: none; }

  /* How it works */
  .hiw-card {
    background: var(--gray);
    border-radius: 12px;
    padding: 32px 24px;
    text-align: center;
  }
  .hiw-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: 2px solid var(--red);
    color: var(--red);
    font-weight: 700;
    margin-bottom: 16px;
  }
  .hiw-card h3 { font-size: 1.05rem; margin-bottom: 8px; }
  .hiw-card p { color: var(--gray-text); font-size: 0.9rem; }

  /* Contact */
  .about-contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    align-items: center;
  }
  .contact-person {
    display: flex;
    align-items: center;
    gap: 16px;
    margin: 24px 0;
  }
  .contact-avatar {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }
  .contact-name { font-weight: 700; font-size: 1.1rem; }
  .contact-role { color: var(--gray-text); font-size: 0.85rem; }
  .contact-details { display: flex; flex-direction: column; gap: 8px; }
  .contact-details a { font-weight: 500; }
  .contact-details a:hover { color: var(--red); }
  .about-contact-img {
    width: 100%;
    height: 250px;
    object-fit: cover;
    border-radius: 12px;
  }

  @media (min-width: 768px) {
    .about-hero-grid { grid-template-columns: 1fr 1fr; }
    .services-grid { grid-template-columns: repeat(3, 1fr); }
    .about-contact-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (min-width: 1024px) {
    .services-grid { grid-template-columns: repeat(4, 1fr); }
  }
</style>

<script>
document.querySelectorAll(".faq-question").forEach(btn => {
  btn.addEventListener("click", () => { btn.parentElement?.classList.toggle("active"); });
});
</script>
