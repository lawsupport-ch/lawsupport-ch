---
import Base from '../layouts/Base.astro';
---
<Base title="Page Not Found — Lawsupport.ch" description="The page you are looking for does not exist.">
  <section class="section">
    <div class="container" style="text-align:center;min-height:40vh;display:flex;flex-direction:column;align-items:center;justify-content:center">
      <h1>404</h1>
      <p style="color:#555;margin:16px 0 32px;max-width:480px">The page you are looking for does not exist or has been moved.</p>
      <a href="/" class="btn btn-red">Back to Homepage</a>
    </div>
  </section>
</Base>
