---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => {
  if (!data.publishDate) return true;
  return new Date(data.publishDate) <= new Date();
});

const articles = allPosts
  .sort((a, b) => {
    const dateA = a.data.date.split('.').reverse().join('-');
    const dateB = b.data.date.split('.').reverse().join('-');
    return dateB.localeCompare(dateA);
  })
  .map(post => ({
    title: post.data.title,
    href: `/blog/${post.id}/`,
    category: post.data.category,
    date: post.data.date,
    description: post.data.description,
  }));

const categories = [...new Set(articles.map(a => a.category))].sort();

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": "Blog — Swiss Corporate Law & Company Formation Guides",
    "url": "https://lawsupport.ch/blog/"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://lawsupport.ch/" },
      { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://lawsupport.ch/blog/" }
    ]
  }
];
---

<Base title="Blog — Swiss Corporate Law & Company Formation Guides" description="Expert guides on Swiss company formation, corporate law, tax planning, and business setup. Practical advice from experienced Swiss lawyers." schema={schema}>

  <div class="container">
    <nav class="breadcrumb">
      <a href="/">Home</a> <span>/</span> <span>Blog</span>
    </nav>
  </div>

  <section class="section">
    <div class="container">
      <h1>Blog — Swiss Corporate Law Guides</h1>
      <p class="blog-lead">Articles and guides about corporate services in Switzerland.</p>
      <div class="blog-filters">
        <button class="blog-filter active" data-filter="all">All ({articles.length})</button>
        {categories.map(cat => (
          <button class="blog-filter" data-filter={cat}>{cat}</button>
        ))}
      </div>
      <div class="grid-3 blog-grid">
        {articles.map(article => (
          <a href={article.href} class="card" data-category={article.category}>
            <div class="card-body">
              <span class="blog-card-category">{article.category}</span>
              <h3>{article.title}</h3>
              <span class="blog-card-date">{article.date}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

</Base>

<style>
  .blog-lead { color: var(--gray-text); margin: 12px 0 40px; }
  .blog-card-category {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--red);
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .blog-card-date { font-size: 0.8rem; color: var(--gray-text); margin-top: 8px; display: block; }
  .blog-filters {
    display: flex;
    gap: 8px;
    margin-bottom: 32px;
    flex-wrap: wrap;
  }
  .blog-filter {
    padding: 8px 20px;
    border-radius: 24px;
    font-size: 0.85rem;
    font-weight: 500;
    background: var(--gray);
    color: var(--gray-text);
    border: 1px solid var(--gray-border);
    cursor: pointer;
    transition: all 0.2s;
  }
  .blog-filter:hover { border-color: var(--red); color: var(--black); }
  .blog-filter.active { background: var(--red); color: var(--white); border-color: var(--red); }
</style>

<script>
  document.querySelectorAll(".blog-filter").forEach(btn => {
    btn.addEventListener("click", () => {
      document.querySelectorAll(".blog-filter").forEach(b => b.classList.remove("active"));
      btn.classList.add("active");
      const filter = btn.dataset.filter;
      document.querySelectorAll(".blog-grid .card").forEach(card => {
        (card as HTMLElement).style.display = (filter === "all" || card.dataset.category === filter) ? "" : "none";
      });
    });
  });
</script>
