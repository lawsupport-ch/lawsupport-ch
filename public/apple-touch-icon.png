7177\",\"static/chunks/app/layout-1ed598afe9e62f7d.js\"],\"NewsProvider\"]\n10:T4f8,"])</script><script>self.__next_f.push([1,"{\"@context\":\"https://schema.org\",\"@type\":\"Organization\",\"name\":\"Lawsupport\",\"description\":\"Lawsupport provides expert corporate services in Switzerland. From company formation to bank account setup, accounting, legal support, and migration assistance — we guide businesses every step of the way.\",\"url\":\"https://lawsupport.ch\",\"logo\":\"https://lawsupport.ch/favicon.ico\",\"foundingDate\":\"2007-01-01\",\"address\":{\"@type\":\"PostalAddress\",\"streetAddress\":\"Stockerstrasse 45\",\"addressLocality\":\"Zürich\",\"addressCountry\":\"CH\"},\"contactPoint\":[{\"@type\":\"ContactPoint\",\"telephone\":\"+41-44-515-2590\",\"contactType\":\"customer support\",\"areaServed\":\"CH\",\"availableLanguage\":[\"en\",\"de\",\"fr\",\"it\"]}],\"sameAs\":[\"https://www.facebook.com/goldblum.and.partners\",\"https://www.instagram.com/law_support.switzerland\",\"https://x.com/Law_Switzerland\"],\"makesOffer\":[{\"@type\":\"Offer\",\"itemOffered\":{\"@type\":\"Service\",\"name\":\"Legal support\"}},{\"@type\":\"Offer\",\"itemOffered\":{\"@type\":\"Service\",\"name\":\"Company formation\"}},{\"@type\":\"Offer\",\"itemOffered\":{\"@type\":\"Service\",\"name\":\"Swiss bank account setup\"}},{\"@type\":\"Offer\",\"itemOffered\":{\"@type\":\"Service\",\"name\":\"Accounting and bookkeeping\"}},{\"@type\":\"Offer\",\"itemOffered\":{\"@type\":\"Service\",\"name\":\"Migration \u0026 resident card assistance\"}}]}"])</script><script>self.__next_f.push([1,"2:[\"$\",\"html\",null,{\"lang\":\"en\",\"className\":\"__variable_3f6596 __variable_4fe00c\",\"children\":[[\"$\",\"head\",null,{\"children\":[[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"$10\"}}],[\"$\",\"script\",null,{\"type\":\"application/ld+json\",\"dangerouslySetInnerHTML\":{\"__html\":\"{\\\"@context\\\":\\\"https://schema.org\\\",\\\"@type\\\":\\\"WebSite\\\",\\\"name\\\":\\\"Lawsupport\\\",\\\"url\\\":\\\"https://lawsupport.ch\\\",\\\"inLanguage\\\":\\\"en\\\",\\\"description\\\":\\\"Lawsupport helps businesses start and operate in Switzerland, including company formation, Swiss bank account setup, accounting, legal support, and migration assistance.\\\",\\\"publisher\\\":{\\\"@type\\\":\\\"Organization\\\",\\\"name\\\":\\\"Lawsupport\\\",\\\"url\\\":\\\"https://lawsupport.ch\\\",\\\"logo\\\":{\\\"@type\\\":\\\"ImageObject\\\",\\\"url\\\":\\\"https://lawsupport.ch/favicon.ico\\\"}},\\\"potentialAction\\\":{\\\"@type\\\":\\\"SearchAction\\\",\\\"target\\\":\\\"https://lawsupport.ch/?search={search_term_string}\\\",\\\"query-input\\\":\\\"required name=search_term_string\\\"}}\"}}]]}],[\"$\",\"body\",null,{\"className\":\"flex flex-col min-h-screen\",\"children\":[[\"$\",\"$L11\",null,{}],[\"$\",\"$L12\",null,{\"initialArticles\":[{\"id\":61,\"slug\":\"company-formation-switzerland\",\"title\":\"Swiss Company Formation: Complete Guide to AG and GmbH Registration\",\"description\":\"This guide details the exact procedures, costs, and timelines required to register a company in Switzerland.\",\"date\":\"2026-03-18\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773813466/company_formation_switzerland_870021dbcd.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":10,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":17,\"documentId\":\"oig4de2sfgpnov0hwpswev3j\",\"slug\":\"swiss-company-formation\",\"title_category\":\"Swiss company formation\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-18\",\"CTABlock\":[]},{\"id\":64,\"slug\":\"gmbh-formation-switzerland\",\"title\":\" Structuring a Neurotech Venture From Market Analysis to Swiss GmbH Formation\",\"description\":\"The Brain-Computer Interface (BCI) sector is transitioning from laboratory research to commercial scalability. Recent analytical data indicates a robust capitalization of the industry, with the projected global market volume expected to reach $14.6 billion by 2030.\\n\",\"date\":\"2026-03-18\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773815052/company_swiss_5738a506f8.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":6,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":17,\"documentId\":\"oig4de2sfgpnov0hwpswev3j\",\"slug\":\"swiss-company-formation\",\"title_category\":\"Swiss company formation\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-18\",\"CTABlock\":[]},{\"id\":39,\"slug\":\"international-tax-structuring-switzerland\",\"title\":\"International Tax Structuring Through Switzerland: Treaty Network, Holding Structures, and Transfer Pricing Compliance\",\"description\":\"This page covers treaty mechanics, holding structure options, substance requirements, transfer pricing documentation, cantonal tax differences, and a neutral comparison with other holding jurisdictions. The reader will understand what Swiss tax authorities require, how to model withholding tax savings, and what Lawsupport handles in the setup process.\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773740551/International_taxes_b9dc19875e.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":19,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":40,\"slug\":\"corporate-tax-planning-switzerland\",\"title\":\"Corporate Tax Planning in Switzerland: Rates, Structures, and Legal Optimization Tools\",\"description\":\"This page explains how Swiss corporate tax works, which legal instruments reduce your tax burden, and what the process looks like in practice. We cover cantonal rate differences, optimization tools (holding privilege, patent box, participation exemption), and the procedural steps to implement a tax-efficient structure. \",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773738338/Taxes_5196b7466e.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":17,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":43,\"slug\":\"vat-registration-switzerland\",\"title\":\" VAT Registration in Switzerland (MWST): Requirements, Process, and Compliance for Foreign Companies\",\"description\":\"This page explains the thresholds, current rates, procedural steps, and practical implications for foreign companies operating in or selling into Switzerland.\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773746700/VAT_10bc174012.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":9,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":47,\"slug\":\"tax-residency-switzerland\",\"title\":\"Swiss Tax Residency Transfer Requirements and Procedures\",\"description\":\"This guide explains the requirements for establishing Swiss tax residency as an individual or through a corporate structure. We cover the lump-sum taxation regime (Pauschalbesteuerung), the step-by-step process for non-residents, and the most common mistakes that trigger dual residency conflicts or treaty disputes.\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773751922/Taxesx2_244518b024.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":19,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":49,\"slug\":\"bookkeeping-switzerland\",\"title\":\"Outsourced Accounting for Swiss Companies | Monthly Support, Legal Requirements, and Cost Benchmarks\",\"description\":\"This page explains what monthly accounting support includes, what the law requires, and how outsourced services compare to in-house staff in terms of cost and risk.\",\"date\":\"2026-03-17\",\"author\":\"$undefined\",\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773752680/bookkeeping_763fdd03ba.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":12,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":53,\"slug\":\"corporate-tax-return-switzerland\",\"title\":\"Corporate Tax Return Switzerland Preparation and Filing Guide\",\"description\":\"This guide explains who must file, when, what documents you need, and where foreign company owners typically run into trouble.\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773753570/taxreturn_3e6423b147.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":9,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":55,\"slug\":\"internal-audit-switzerland\",\"title\":\"Internal Audit and Financial Review for Swiss Companies\",\"description\":\"This page explains when internal audit makes sense, what gets examined, and how the process works in practice.\\n\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773754731/internal_audit_a1612caf44.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":18,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":57,\"slug\":\"accounting-recovery-switzerland\",\"title\":\"Accounting Records Recovery Switzerland When and How to Reconstruct Missing Books\",\"description\":\"This page explains the legal framework, the reconstruction process, and what to expect in terms of timeline and cost.\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773755821/accounting_recovery_715b7ff6e2.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":6,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":58,\"slug\":\"tax-ruling-switzerland\",\"title\":\"Swiss Tax Ruling | How to Lock In Your Tax Position Before You Start Operations\",\"description\":\"This page explains what a Swiss tax ruling covers, when you need one, how the process works, and what legal protection it provides. We focus on practical procedure — not theory.\",\"date\":\"2026-03-17\",\"author\":\"$undefined\",\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773744687/Tahes_a285bac362.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":12,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":59,\"slug\":\"tax-advisory-switzerland\",\"title\":\"Swiss Tax Planning | Corporate Rates, Cantonal Differences, and Optimization Strategies\",\"description\":\"This guide outlines the mechanics of Swiss corporate taxation, comparisons of key jurisdictions, and the legal frameworks for holding companies.\",\"date\":\"2026-03-17\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773736166/Taxes_706ee41f34.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":8,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":22,\"documentId\":\"dukn6eg5rua4c89xwrysbopq\",\"slug\":\"accounting-switzerland\",\"title_category\":\"Accounting in Switzerland\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-17\",\"CTABlock\":[]},{\"id\":15,\"slug\":\"corporate-bank-account-switzerland\",\"title\":\"Corporate Bank Account Opening in Switzerland for Foreign Companies\",\"description\":\"This page explains the requirements, timeline, and common rejection reasons. It also describes how Lawsupport assists foreign entrepreneurs through the Swiss banking compliance process.\",\"date\":\"2026-03-16\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773666222/Swiss_bank_febe3355a2.avif\"},\"image\":\"\",\"video\":\"\",\"markdown_article\":\"$undefined\",\"readingTime\":10,\"colorName\":null,\"faqs\":[],\"categories\":[{\"id\":21,\"documentId\":\"v2irnlp429xcq9ppw27a3o25\",\"slug\":\"corporate-bank-account-switzerland\",\"title_category\":\"Swiss bank account\"}],\"metaTitle\":\"\",\"metaDescription\":\"\",\"metaKeywords\":\"\",\"schema\":null,\"ogTitle\":\"\",\"ogDescription\":\"\",\"ogImage\":\"$undefined\",\"updatedAt\":\"2026-03-16\",\"CTABlock\":[]},{\"id\":42,\"slug\":\"accounting-tax-switzerland\",\"title\":\"Accounting and Tax Services in Switzerland\",\"description\":\"We handle the full cycle of financial administration: from primary documentation to representing your interests before the tax authorities in Zug, Zurich, and Geneva. Our corporate governance services ensure compliance at every stage.\",\"date\":\"2026-03-16\",\"author\":{\"id\":2,\"fullNameAuthor\":\"Morgan Hartley\",\"slugAuthor\":\"$undefined\",\"position\":\"$undefined\",\"imgAuthor\":\"$undefined\"},\"imageArticle\":{\"url\":\"https://res.cloudinary.com/ddjf4wivx/image/upload/v1773736107/Swiss_Flag_e1f7f0aee3.avif\"},\"image\":\"\",\"video\":\"